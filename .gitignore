# Datos brutos (demasiado grandes para Git, descargar de fuentes oficiales)
data/raw/entradas_salidas/Datos_abiertos*/
data/raw/entradas_salidas/datos_abiertos_ESI/
data/raw/entradas_salidas/*.csv
!data/raw/entradas_salidas/muestra_*.csv
data/external/*
!data/external/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/*.csv

# Mantener metadatos y muestras pequeñas
!data/FUENTES_DATOS.md
!data/raw/banco_mundial/*.zip
!data/raw/seguridad/*.xlsx
!data/raw/seguridad/*.csv
# Excepcion: homicidios diarios (89 MB) no usado por los analisis; descargar segun FUENTES_DATOS.md
data/raw/seguridad/mdi_homicidios_intencionales_dd_2014_2024.xlsx
!data/raw/catastro/*
!data/raw/turismo_interno/*
!data/raw/unwto/*

# Entornos virtuales Python
venv/
.venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Node / frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env*.local
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Outputs (figuras y tablas se regeneran al ejecutar el codigo)
outputs/*
!outputs/.gitkeep

# Documento Word compilado
*.docx
~$*.docx
~$*.xlsx

# Logs y temporales
*.log
*.tmp
.tmp/
.cache/

# Credenciales
.env
.env.local
secrets.yml
*.pem
*.key
